/*
  # Security Headers for LexRadar v2.0
  # Deploy to Cloudflare or use with GitHub Pages

  # Prevent clickjacking
  X-Frame-Options: DENY
  
  # Prevent MIME type sniffing
  X-Content-Type-Options: nosniff
  
  # Enable XSS protection (legacy, most modern browsers ignore)
  X-XSS-Protection: 1; mode=block
  
  # Referrer Policy
  Referrer-Policy: strict-origin-when-cross-origin
  
  # Permissions Policy (formerly Feature-Policy)
  Permissions-Policy: geolocation=(), microphone=(), camera=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  
  # Content Security Policy (strict, update as needed for your external resources)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://lexradar-api.jolly-lab-c60a.workers.dev; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests
  
  # Strict Transport Security (HSTS)
  # Requires HTTPS. Comment out if not using HTTPS.
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  
  # Cache-Control for index
/index.html
  Cache-Control: public, max-age=3600, must-revalidate
  
  # Cache-Control for assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  
  # Cache-Control for data
/data/*
  Cache-Control: public, max-age=3600
  
  # Cache-Control for API calls (Worker response, if cacheable)
/api/*
  Cache-Control: private, no-cache, no-store, must-revalidate

# Default fallback for SPA
/*
  Cache-Control: public, max-age=3600, must-revalidate
